@using client.Models
@using client.Services
@inject StudySessionService SessionService

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>Date</th>
                <th>Category</th>
                <th>Hours</th>
                <th>Notes</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var session in Sessions.OrderByDescending(s => s.Date))
            {
                <tr>
                    <td>@session.Date.ToShortDateString()</td>
                    <td>@session.Category</td>
                    <td>@session.Hours</td>
                    <td>@(string.IsNullOrEmpty(session.Notes) ? "-" : session.Notes)</td>
                    <td>
                        <div class="btn-group btn-group-sm" role="group">
                            <button class="btn btn-outline-primary" @onclick="() => OnEditSession.InvokeAsync(session)" title="Edit">
                                <i class="bi bi-pencil"></i> Edit
                            </button>
                            <button class="btn btn-outline-danger" @onclick="() => HandleDelete(session)" title="Delete">
                                <i class="bi bi-trash"></i> Delete
                            </button>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (showDeleteConfirm)
{
    <div class="modal d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirm Delete</h5>
                    <button type="button" class="btn-close" @onclick="CancelDelete"></button>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to delete this study session?</p>
                    <p><strong>@sessionToDelete?.Category</strong> - @sessionToDelete?.Hours hours on @sessionToDelete?.Date.ToShortDateString()</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CancelDelete">Cancel</button>
                    <button type="button" class="btn btn-danger" @onclick="ConfirmDelete">Delete</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] 
    public List<StudySession> Sessions { get; set; } = new();
    
    [Parameter] 
    public EventCallback OnSessionUpdated { get; set; }

    [Parameter]
    public EventCallback<StudySession> OnEditSession { get; set; }

    private bool showDeleteConfirm = false;
    private StudySession? sessionToDelete;

    private void HandleDelete(StudySession session)
    {
        sessionToDelete = session;
        showDeleteConfirm = true;
    }

    private void CancelDelete()
    {
        showDeleteConfirm = false;
        sessionToDelete = null;
    }

    private async Task ConfirmDelete()
    {
        if (sessionToDelete != null)
        {
            var success = await SessionService.DeleteSessionAsync(sessionToDelete.Id);
            if (success)
            {
                showDeleteConfirm = false;
                sessionToDelete = null;
                await OnSessionUpdated.InvokeAsync();
            }
        }
    }
}
