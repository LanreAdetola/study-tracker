@using client.Models
@using client.Services
@inject StudySessionService SessionService
@inject StudyGoalService GoalService

<div class="card mb-4">
    <div class="card-body">
        <h5 class="card-title">@(IsEditMode ? "Edit Study Session" : "Add New Study Session")</h5>
        <EditForm Model="currentSession" OnValidSubmit="HandleSubmit">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="mb-3">
                <label class="form-label">Category</label>
                <div class="input-group">
                    @if (activeGoals.Any())
                    {
                        <InputSelect class="form-select" @bind-Value="currentSession.Category">
                            <option value="">-- Select from goals or type custom --</option>
                            @foreach (var goal in activeGoals)
                            {
                                <option value="@goal.Name">@goal.Name (@goal.Type)</option>
                            }
                        </InputSelect>
                        <button class="btn btn-outline-secondary" type="button" @onclick="ToggleCustomCategory">
                            <i class="bi bi-pencil"></i>
                        </button>
                    }
                    else
                    {
                        <InputText class="form-control" @bind-Value="currentSession.Category" placeholder="Enter category" />
                    }
                </div>
                @if (showCustomCategory)
                {
                    <InputText class="form-control mt-2" @bind-Value="currentSession.Category" placeholder="Enter custom category" />
                }
                <ValidationMessage For="() => currentSession.Category" />
            </div>

            <div class="mb-3">
                <label class="form-label">Hours</label>
                <InputNumber class="form-control" @bind-Value="currentSession.Hours" />
                <ValidationMessage For="() => currentSession.Hours" />
            </div>

            <div class="mb-3">
                <label class="form-label">Date</label>
                <InputDate class="form-control" @bind-Value="currentSession.Date" />
                <ValidationMessage For="() => currentSession.Date" />
            </div>

            <div class="mb-3">
                <label class="form-label">Notes (optional)</label>
                <InputTextArea class="form-control" @bind-Value="currentSession.Notes" rows="3" />
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    @(IsEditMode ? "Update Session" : "Add Session")
                </button>
                @if (IsEditMode)
                {
                    <button type="button" class="btn btn-secondary" @onclick="CancelEdit">Cancel</button>
                }
            </div>
        </EditForm>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnSessionAdded { get; set; }

    [Parameter]
    public StudySession? SessionToEdit { get; set; }

    [Parameter]
    public EventCallback OnEditCancelled { get; set; }

    private StudySession currentSession = new() { Date = DateTime.Today };
    private List<StudyGoal> activeGoals = new();
    private bool IsEditMode => SessionToEdit != null;
    private bool showCustomCategory = false;

    protected override async Task OnInitializedAsync()
    {
        activeGoals = await GoalService.GetActiveGoalsAsync();
    }

    protected override void OnParametersSet()
    {
        if (SessionToEdit != null)
        {
            // Create a copy for editing
            currentSession = new StudySession
            {
                Id = SessionToEdit.Id,
                UserId = SessionToEdit.UserId,
                UserName = SessionToEdit.UserName,
                Category = SessionToEdit.Category,
                Hours = SessionToEdit.Hours,
                Date = SessionToEdit.Date,
                Notes = SessionToEdit.Notes
            };
        }
        else
        {
            currentSession = new() { Date = DateTime.Today };
        }
        showCustomCategory = false;
    }

    private void ToggleCustomCategory()
    {
        showCustomCategory = !showCustomCategory;
        if (showCustomCategory)
        {
            currentSession.Category = string.Empty;
        }
    }

    private async Task HandleSubmit()
    {
        bool success;
        
        if (IsEditMode)
        {
            success = await SessionService.UpdateSessionAsync(currentSession);
        }
        else
        {
            success = await SessionService.AddSessionAsync(currentSession);
        }
        
        if (success)
        {
            currentSession = new() { Date = DateTime.Today };
            showCustomCategory = false;
            await OnSessionAdded.InvokeAsync();
        }
    }

    private async Task CancelEdit()
    {
        currentSession = new() { Date = DateTime.Today };
        showCustomCategory = false;
        await OnEditCancelled.InvokeAsync();
    }
}
