@using Microsoft.AspNetCore.Components.Authorization

<div class="@NavMenuCssClass nav-scrollable" @onclick="ToggleNavMenu">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill" aria-hidden="true"></span> Home
            </NavLink>
        </div>

        <AuthorizeView>
            <Authorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="goals">
                        <span class="bi bi-trophy-fill" aria-hidden="true"></span> My Goals
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="study-log">
                        <span class="bi bi-plus-circle-fill" aria-hidden="true"></span> Log a New Session
                    </NavLink>
                </div>
            </Authorized>
        </AuthorizeView>

        <!-- Login/Logout Section -->
        <div class="nav-item px-3">
            <AuthorizeView>
                <Authorized Context="authContext">
                    <div class="nav-link mb-2">
                        Hello, @authContext.User.Identity?.Name!
                    </div>
                    <a class="nav-link" href="/.auth/logout">Logout</a>
                </Authorized>
                <NotAuthorized>
                    <a class="nav-link" href="/.auth/login/github">Login with GitHub</a>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </nav>
</div>

@code {
    private bool collapseNavMenu = true;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }
}
