@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@using client.Components

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <AuthorizeView>
            <Authorized Context="topBarAuth">
                <div class="top-row px-4 d-flex justify-content-end align-items-center">
                    <span>Hello, @topBarAuth.User.Identity?.Name!</span>
                </div>
            </Authorized>
            <NotAuthorized>
                <div class="top-row px-4 d-flex justify-content-end align-items-center d-none d-md-flex">
                    <span>Please log in</span>
                </div>
            </NotAuthorized>
        </AuthorizeView>

        <article class="content px-4">
            <UserRegistration />
            @Body
        </article>
    </main>
</div>
