@page "/"
@using client.Models
@using client.Services
@inject StudySessionService SessionService
@inject StudyGoalService GoalService
@inject UserService UserService
@inject AuthenticationStateProvider AuthStateProvider

<AuthorizeView>
    <Authorized>
        <h3>Welcome, @userName!</h3>

        <div class="kpi-grid">
            <div class="kpi-card">
                <h6 class="text-muted mb-1">Total Sessions</h6>
                <p class="kpi-value">@(stats?.TotalSessions ?? 0)</p>
            </div>
            <div class="kpi-card">
                <h6 class="text-muted mb-1">Total Hours</h6>
                <p class="kpi-value">@((stats?.TotalHours ?? 0).ToString("F1"))</p>
            </div>
            <div class="kpi-card">
                <h6 class="text-muted mb-1">Study Streak</h6>
                <p class="kpi-value">@(stats?.CurrentStreak ?? 0) <span class="kpi-unit">days</span></p>
                <p class="kpi-sub">Longest: @(stats?.LongestStreak ?? 0) days</p>
            </div>
            <div class="kpi-card">
                <h6 class="text-muted mb-1">This Week</h6>
                <p class="kpi-value">@((stats?.ThisWeekHours ?? 0).ToString("F1")) <span class="kpi-unit">hrs</span></p>
                @if (stats != null)
                {
                    var diff = stats.ThisWeekHours - stats.LastWeekHours;
                    <p class="kpi-sub @(diff > 0 ? "trend-up" : diff < 0 ? "trend-down" : "trend-equal")">
                        @(diff > 0 ? "+" : "")@diff.ToString("F1") vs last week
                    </p>
                }
            </div>
        </div>

        <!-- Active Goals Progress -->
        <div class="mt-4">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <h5 class="mb-0">Active Goals</h5>
                <a href="goals" class="text-decoration-none small">View all</a>
            </div>
            @if (activeGoals == null || !activeGoals.Any())
            {
                <div class="card">
                    <div class="card-body text-center text-muted py-3">
                        No active goals. <a href="goals">Create a goal</a> to track progress.
                    </div>
                </div>
            }
            else
            {
                @foreach (var goal in activeGoals.Take(3))
                {
                    var pct = goal.TargetHours > 0
                        ? Math.Min((goal.CurrentHours / goal.TargetHours) * 100, 100) : 0;
                    var isComplete = goal.CurrentHours >= goal.TargetHours && goal.TargetHours > 0;
                    <div class="card mb-2">
                        <div class="card-body py-2 px-3">
                            <div class="d-flex justify-content-between small mb-1">
                                <span class="fw-medium">
                                    @goal.Name
                                    @if (isComplete)
                                    {
                                        <span class="badge bg-success ms-1">Done</span>
                                    }
                                </span>
                                <span class="text-muted">@goal.CurrentHours.ToString("F1")/@goal.TargetHours hrs</span>
                            </div>
                            <div class="progress" style="height: 8px;">
                                <div class="progress-bar @(isComplete ? "bg-success" : "")"
                                     role="progressbar"
                                     style="width: @(pct)%;"
                                     aria-valuenow="@pct" aria-valuemin="0" aria-valuemax="100">
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </Authorized>
    <NotAuthorized>
        <div class="hero-section">
            <div class="hero-content">
                <h1 class="hero-title">Study Tracker</h1>
                <p class="hero-tagline">Track your study progress and achieve your goals</p>

                @if (userCount != null)
                {
                    <p class="user-count">
                        @if (userCount.CanRegister)
                        {
                            <span class="badge bg-success">@userCount.Count/@userCount.MaxUsers students joined</span>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark">@userCount.Count/@userCount.MaxUsers spots filled</span>
                        }
                    </p>
                }

                <div class="cta-section">
                    @if (userCount?.CanRegister == false)
                    {
                        <button class="btn btn-secondary btn-lg" disabled>App at Capacity</button>
                        <p class="text-muted mt-2">We're at our 50-user limit. Check back later!</p>
                    }
                    else
                    {
                        <div class="login-options">
                            <a href="/.auth/login/github" class="btn btn-dark btn-lg">Login with GitHub</a>
                            <a href="/.auth/login/aad" class="btn btn-primary btn-lg">Login with Microsoft</a>
                        </div>
                    }
                </div>

                <div class="feature-cards">
                    <div class="feature-card">
                        <div class="feature-icon">🎯</div>
                        <div>
                            <h3>Set Goals</h3>
                            <p>Create study goals for subjects and certifications</p>
                        </div>
                    </div>
                    <div class="feature-card">
                        <div class="feature-icon">📝</div>
                        <div>
                            <h3>Log Sessions</h3>
                            <p>Track your study hours and progress</p>
                        </div>
                    </div>
                    <div class="feature-card">
                        <div class="feature-icon">📊</div>
                        <div>
                            <h3>Monitor Progress</h3>
                            <p>View your achievements and stay motivated</p>
                        </div>
                    </div>
                </div>

                <p class="tech-badge">Built with Blazor WebAssembly</p>
            </div>
        </div>
    </NotAuthorized>
</AuthorizeView>

@code {
    private string userName = "User";
    private StudySessionStats? stats;
    private List<StudyGoal>? activeGoals;
    private UserCountResponse? userCount = null;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated ?? false)
        {
            userName = user.Identity.Name ?? "User";
            stats = await SessionService.GetStatsAsync();
            activeGoals = await GoalService.GetActiveGoalsAsync();
        }
        else
        {
            userCount = await UserService.GetUserCountAsync();
        }
    }
}
