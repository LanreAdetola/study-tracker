@page "/study-log"
@using Microsoft.AspNetCore.Components.Authorization
@using client.Models
@using client.Services
@using client.Components
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

<AuthorizeView>
    <Authorized>
        <div class="container mt-4">
            <h2>Study Log</h2>
            <p class="text-muted">Track your study sessions and progress over time</p>
            
            <div class="row">
                <div class="col-md-5 mb-4">
                    <div class="card shadow-sm">
                        <div class="card-body">
                            <SessionForm 
                                OnSessionAdded="ReloadSessions"
                                SessionToEdit="selectedSession"
                                OnEditCancelled="CancelEdit" />
                        </div>
                    </div>
                </div>
                <div class="col-md-7">
                    <div class="card shadow-sm">
                        <div class="card-body">
                            <h4 class="card-title mb-3">Your Study History</h4>
                            @if (sessions == null)
                            {
                                <p><em>Loading sessions...</em></p>
                            }
                            else if (!sessions.Any())
                            {
                                <div class="alert alert-info">
                                    <i class="bi bi-info-circle"></i> No study sessions yet. Add your first session to get started!
                                </div>
                            }
                            else
                            {
                                <SessionTable 
                                    Sessions="sessions" 
                                    OnSessionUpdated="ReloadSessions"
                                    OnEditSession="HandleEditSession" />
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </Authorized>
    <NotAuthorized>
        <p>You need to be logged in to access this page.</p>
    </NotAuthorized>
</AuthorizeView>

@code {
    [Inject] private StudySessionService SessionService { get; set; } = default!;
    [Inject] private StudyGoalService GoalService { get; set; } = default!;
    [Inject] private ToastService ToastService { get; set; } = default!;

    private List<StudySession>? sessions;
    private StudySession? selectedSession;

    protected override async Task OnInitializedAsync()
    {
        await ReloadSessions();
    }

    private async Task ReloadSessions()
    {
        // Snapshot goal hours before reload to detect completions
        var goalsBefore = await GoalService.GetActiveGoalsAsync();
        var hoursBefore = goalsBefore.ToDictionary(g => g.Id, g => g.CurrentHours);

        selectedSession = null;
        sessions = await SessionService.GetUserSessionsAsync();

        // Check if any goals just crossed the completion threshold
        var goalsAfter = await GoalService.GetActiveGoalsAsync();
        foreach (var goal in goalsAfter)
        {
            if (goal.TargetHours > 0 &&
                goal.CurrentHours >= goal.TargetHours &&
                hoursBefore.TryGetValue(goal.Id, out var prevHours) &&
                prevHours < goal.TargetHours)
            {
                ToastService.Show($"Goal completed: {goal.Name}!", ToastType.Success);
            }
        }
    }

    private void HandleEditSession(StudySession session)
    {
        selectedSession = session;
        StateHasChanged();
    }

    private async Task CancelEdit()
    {
        selectedSession = null;
        await InvokeAsync(StateHasChanged);
    }
}
