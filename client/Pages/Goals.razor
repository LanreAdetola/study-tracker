@page "/goals"
@using Microsoft.AspNetCore.Components.Authorization
@using client.Models
@using client.Components
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

<AuthorizeView>
    <Authorized>
        <div class="container mt-4">
            <h2>📚 Study Goals</h2>
            <p class="text-muted">Manage your learning objectives and track progress (Maximum 5 goals)</p>

            @if (goals != null && goals.Count >= 5 && selectedGoal == null)
            {
                <div class="alert alert-warning">
                    <i class="bi bi-exclamation-triangle"></i> You have reached the maximum of 5 goals. Delete an existing goal to create a new one.
                </div>
            }

            <!-- Mobile tab bar -->
            <div class="goals-tab-bar d-flex d-md-none mb-3">
                <button class="goals-tab @(activeTab == "goals" ? "active" : "")" @onclick='() => activeTab = "goals"'>
                    My Goals
                </button>
                <button class="goals-tab @(activeTab == "form" ? "active" : "")" @onclick='() => activeTab = "form"'>
                    @(selectedGoal != null ? "Edit Goal" : "Add Goal")
                </button>
            </div>

            <div class="row">
                <!-- Form: always visible on desktop, tab-controlled on mobile -->
                <div class="col-md-5 mb-4 @(activeTab == "form" ? "" : "d-none") d-md-block">
                    <GoalForm
                        OnGoalAdded="OnGoalSaved"
                        GoalToEdit="selectedGoal"
                        OnEditCancelled="CancelEdit" />
                </div>
                <!-- Goals list: always visible on desktop, tab-controlled on mobile -->
                <div class="col-md-7 @(activeTab == "goals" ? "" : "d-none") d-md-block">
                    <div class="card shadow-sm">
                        <div class="card-body">
                            <h4 class="card-title mb-3 d-none d-md-block">Your Goals</h4>
                            @if (goals == null)
                            {
                                <p><em>Loading goals...</em></p>
                            }
                            else if (!goals.Any())
                            {
                                <div class="alert alert-info">
                                    <i class="bi bi-info-circle"></i> No goals yet. Create your first goal to start tracking progress!
                                </div>
                            }
                            else
                            {
                                <div class="list-group">
                                    @foreach (var goal in goals)
                                    {
                                        <div class="list-group-item">
                                            <div class="d-flex justify-content-between align-items-start">
                                                <div class="flex-grow-1">
                                                    <h5 class="mb-1">
                                                        @goal.Name
                                                        @if (!goal.IsActive)
                                                        {
                                                            <span class="badge bg-secondary ms-2">Inactive</span>
                                                        }
                                                    </h5>
                                                    <p class="mb-1 text-muted">
                                                        <span class="badge bg-primary">@goal.Type</span>
                                                        <span class="ms-2">Target: @goal.TargetHours hours</span>
                                                        @if (goal.TargetDate.HasValue)
                                                        {
                                                            <span class="ms-2">Due: @goal.TargetDate.Value.ToShortDateString()</span>
                                                        }
                                                    </p>
                                                    <div class="progress mb-2" style="height: 20px;">
                                                        @{
                                                            var progressPercent = goal.TargetHours > 0
                                                                ? Math.Min((goal.CurrentHours / goal.TargetHours) * 100, 100)
                                                                : 0;
                                                        }
                                                        <div class="progress-bar" role="progressbar"
                                                             style="width: @(progressPercent)%;"
                                                             aria-valuenow="@progressPercent"
                                                             aria-valuemin="0"
                                                             aria-valuemax="100">
                                                            @goal.CurrentHours.ToString("F1") / @goal.TargetHours hours (@progressPercent.ToString("F0")%)
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="btn-group btn-group-sm ms-3 d-none d-md-flex" role="group">
                                                    <button class="btn btn-outline-primary" @onclick="() => HandleEditGoal(goal)">Edit</button>
                                                    <button class="btn btn-outline-danger" @onclick="() => HandleDelete(goal)">Delete</button>
                                                </div>
                                            </div>
                                            <div class="d-flex d-md-none gap-2 mt-2">
                                                <button class="btn btn-sm btn-outline-primary" @onclick="() => HandleEditGoal(goal)">Edit</button>
                                                <button class="btn btn-sm btn-outline-danger" @onclick="() => HandleDelete(goal)">Delete</button>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @if (showDeleteConfirm)
        {
            <div class="modal d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
                <div class="modal-dialog modal-dialog-centered modal-fullscreen-sm-down">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title">Confirm Delete</h5>
                            <button type="button" class="btn-close" @onclick="CancelDelete"></button>
                        </div>
                        <div class="modal-body">
                            <p>Are you sure you want to delete this goal?</p>
                            <p><strong>@goalToDelete?.Name</strong> (@goalToDelete?.Type - @goalToDelete?.TargetHours hours)</p>
                            <p class="text-warning"><i class="bi bi-exclamation-triangle"></i> This action cannot be undone.</p>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" @onclick="CancelDelete">Cancel</button>
                            <button type="button" class="btn btn-danger" @onclick="ConfirmDelete">Delete</button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </Authorized>
    <NotAuthorized>
        <p>You need to be logged in to access this page.</p>
    </NotAuthorized>
</AuthorizeView>

@code {
    [Inject] private StudyGoalService GoalService { get; set; } = default!;

    private List<StudyGoal>? goals;
    private StudyGoal? selectedGoal;
    private bool showDeleteConfirm = false;
    private StudyGoal? goalToDelete;
    private string activeTab = "goals";

    protected override async Task OnInitializedAsync()
    {
        await ReloadGoals();
    }

    private async Task ReloadGoals()
    {
        selectedGoal = null;
        goals = await GoalService.GetUserGoalsAsync();
    }

    private async Task OnGoalSaved()
    {
        await ReloadGoals();
        activeTab = "goals";
    }

    private void HandleEditGoal(StudyGoal goal)
    {
        selectedGoal = goal;
        activeTab = "form";
        StateHasChanged();
    }

    private async Task CancelEdit()
    {
        selectedGoal = null;
        activeTab = "goals";
        await InvokeAsync(StateHasChanged);
    }

    private void HandleDelete(StudyGoal goal)
    {
        goalToDelete = goal;
        showDeleteConfirm = true;
    }

    private void CancelDelete()
    {
        showDeleteConfirm = false;
        goalToDelete = null;
    }

    private async Task ConfirmDelete()
    {
        if (goalToDelete != null)
        {
            var success = await GoalService.DeleteGoalAsync(goalToDelete.Id);
            if (success)
            {
                showDeleteConfirm = false;
                goalToDelete = null;
                await ReloadGoals();
            }
        }
    }
}
